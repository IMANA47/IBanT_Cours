void main() {

    TRISD = 0;
    PORTD = 0;

    while(1) {

        /*
        F0 = V1
        F1 = O1
        F2 = R1
        F3 = V2
        F4 = O2
        F5 = R2
        */

        // ====================
        // ETAPE 1
        // ====================

        PORTD.F0 = 1; // V1 ON
        PORTD.F5 = 1; // R2 ON

        Delay_ms(5000);

        // ====================
        // ETAPE 2
        // ====================

        PORTD.F0 = 0; // V1 OFF
        PORTD.F4 = 1; // O2 ON

        Delay_ms(3000);

        // ====================
        // ETAPE 3
        // ====================

        PORTD.F4 = 0; // O2 OFF

        PORTD.F1 = 1; // O1 ON
        PORTD.F3 = 1; // V2 ON

        Delay_ms(3000);

        // ====================
        // ETAPE 4
        // ====================

        PORTD.F1 = 0; // O1 OFF
        PORTD.F2 = 1; // R1 ON

        Delay_ms(5000);

        // ====================
        // ETAPE 5
        // ====================

        PORTD.F2 = 0; // R1 OFF
        PORTD.F3 = 0; // V2 OFF

        PORTD.F1 = 1; // O1 ON
        PORTD.F4 = 1; // O2 ON

        Delay_ms(3000);

        PORTD.F1 = 0;
        PORTD.F4 = 0;
    }
}
